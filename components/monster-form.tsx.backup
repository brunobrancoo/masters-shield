                            name: e.target.value,
                          };
                          updateField("reactions", updated);
                        }}
                        placeholder="Nome da reação"
                        className="bg-card"
                      />
                      <Textarea
                        value={reaction.desc}
                        onChange={(e) => {
                          const updated = [...(formData.reactions || [])];
                          updated[idx] = {

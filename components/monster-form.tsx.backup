                            desc: e.target.value,
                          };
                          updateField("reactions", updated);
                        }}
                        placeholder="Descrição"
                        className="bg-card"
                      />
                    </div>
                    <Button
                      type="button"
                      variant="destructive"
                      size="sm"
                      onClick={() => removeArrayItem("reactions", idx)}
                    >
                      X
                    </Button>
                  </div>
                </div>
              ))}
              <Button
                type="button"
                variant="outline"
                onClick={() =>
                  addArrayItem("reactions", { name: "", desc: "" })
                }
                className="w-full"
              >
                + Adicionar Reação
              </Button>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Habilidades Especiais
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-3 max-h-64 overflow-y-auto">
              {(formData.special_abilities || []).map(
                (ability: any, idx: number) => (
                  <div
                    key={idx}
                    className="p-3 border border-border rounded space-y-2"
                  >
                    <div className="flex gap-2 items-start">
                      <div className="flex-1 space-y-2">
                        <Input
                          value={ability.name}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.special_abilities || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              name: e.target.value,
                            };
                            updateField("special_abilities", updated);
                          }}
                          placeholder="Nome da habilidade"
                          className="bg-card"
                        />
                        <Input
                          type="number"
                          value={ability.attack_bonus || ""}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.special_abilities || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              attack_bonus:
                                parseInt(e.target.value) || undefined,
                            };
                            updateField("special_abilities", updated);
                          }}
                          placeholder="Bônus de Ataque"
                          className="bg-card"
                        />
                        <Textarea
                          value={ability.desc}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.special_abilities || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              desc: e.target.value,
                            };
                            updateField("special_abilities", updated);
                          }}
                          placeholder="Descrição"
                          className="bg-card"
                        />
                      </div>
                      <Button
                        type="button"
                        variant="destructive"
                        size="sm"
                        onClick={() =>
                          removeArrayItem("special_abilities", idx)
                        }
                      >
                        X
                      </Button>
                    </div>
                  </div>
                ),
              )}
              <Button
                type="button"
                variant="outline"
                onClick={() =>
                  addArrayItem("special_abilities", { name: "", desc: "" })
                }
                className="w-full"
              >
                + Adicionar Habilidade
              </Button>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Ações Lendárias
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-3 max-h-64 overflow-y-auto">
              {(formData.legendary_actions || []).map(
                (action: any, idx: number) => (
                  <div
                    key={idx}
                    className="p-3 border border-border rounded space-y-2"
                  >
                    <div className="flex gap-2 items-start">
                      <div className="flex-1 space-y-2">
                        <Input
                          value={action.name}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.legendary_actions || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              name: e.target.value,
                            };
                            updateField("legendary_actions", updated);
                          }}
                          placeholder="Nome da ação"
                          className="bg-card"
                        />
                        <Input
                          type="number"
                          value={action.attack_bonus || ""}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.legendary_actions || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              attack_bonus:
                                parseInt(e.target.value) || undefined,
                            };
                            updateField("legendary_actions", updated);
                          }}
                          placeholder="Bônus de Ataque"
                          className="bg-card"
                        />
                        <Textarea
                          value={action.desc}
                          onChange={(e) => {
                            const updated = [
                              ...(formData.legendary_actions || []),
                            ];
                            updated[idx] = {
                              ...updated[idx],
                              desc: e.target.value,
                            };
                            updateField("legendary_actions", updated);
                          }}
                          placeholder="Descrição"
                          className="bg-card"
                        />
                      </div>
                      <Button
                        type="button"
                        variant="destructive"
                        size="sm"
                        onClick={() =>
                          removeArrayItem("legendary_actions", idx)
                        }
                      >
                        X
                      </Button>
                    </div>
                  </div>
                ),
              )}
              <Button
                type="button"
                variant="outline"
                onClick={() =>
                  addArrayItem("legendary_actions", { name: "", desc: "" })
                }
                className="w-full"
              >
                + Adicionar Ação Lendária
              </Button>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Status & Combate
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="status">Status</Label>
                  <select
                    id="status"
                    value={formData.status || "alive"}
                    onChange={(e) =>
                      updateField("status", e.target.value as any)
                    }
                    className="w-full bg-card border rounded-md px-3 py-2"
                  >
                    <option value="alive">Vivo</option>
                    <option value="unconscious">Inconsciente</option>
                    <option value="dead">Morto</option>
                  </select>
                </div>
                <div className="space-y-2">
                  <Label htmlFor="concentration_active">
                    Concentração Ativa
                  </Label>
                  <select
                    id="concentration_active"
                    value={formData.concentration?.active ? "true" : "false"}
                    onChange={(e) =>
                      updateField("concentration", {
                        active: e.target.value === "true",
                        spell: formData.concentration?.spell,
                      })
                    }
                    className="w-full bg-card border rounded-md px-3 py-2"
                  >
                    <option value="false">Não</option>
                    <option value="true">Sim</option>
                  </select>
                </div>
              </div>
              {formData.concentration?.active && (
                <div className="space-y-2">
                  <Label htmlFor="concentration_spell">
                    Magia de Concentração
                  </Label>
                  <Input
                    id="concentration_spell"
                    value={formData.concentration?.spell?.name || ""}
                    onChange={(e) =>
                      updateField("concentration", {
                        active: true,
                        spell: { name: e.target.value, level: 0 },
                      })
                    }
                    placeholder="Nome da magia"
                    className="bg-card"
                    />
                 </div>
               </div>

              <div className="mt-6 pt-6 border-t border-border-default">
                <div className="flex items-center gap-2 mb-3">
                  <Wand2 className="w-4 h-4 text-arcane-400" />
                  <h4 className="font-semibold text-text-secondary">
                    Slots de Magia
                  </h4>
                </div>
                <div className="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-4">
                  {[1, 2, 3, 4, 5, 6, 7, 8, 9].map((lvl) => {
                    const slotData = formData.spellSlots?.[lvl as keyof typeof formData.spellSlots] || { current: 0, max: 0 };

                    return (
                      <div key={lvl}>
                        <div className="flex items-center gap-1 mb-2">
                          <span className="text-xs font-medium text-text-tertiary">
                            Nível {lvl}
                          </span>
                        </div>
                        <div className="space-y-2">
                          <div>
                            <Label htmlFor={`spell-slot-max-${lvl}`} className="text-xs text-text-tertiary">
                              Máximo
                            </Label>
                            <Input
                              id={`spell-slot-max-${lvl}`}
                              type="number"
                              min="0"
                              className="bg-bg-inset border-border-default focus:border-arcane-400 text-center h-9 text-sm"
                              value={slotData.max}
                              onChange={(e) => {
                                const newSpellSlots = formData.spellSlots || {
                                  1: { current: 0, max: 0 },
                                  2: { current: 0, max: 0 },
                                  3: { current: 0, max: 0 },
                                  4: { current: 0, max: 0 },
                                  5: { current: 0, max: 0 },
                                  6: { current: 0, max: 0 },
                                  7: { current: 0, max: 0 },
                                  8: { current: 0, max: 0 },
                                  9: { current: 0, max: 0 },
                                };
                                updateField("spellSlots", {
                                  ...newSpellSlots,
                                  [lvl]: {
                                    current: slotData.current,
                                    max: parseInt(e.target.value) || 0,
                                  },
                                });
                              }}
                              placeholder="0"
                            />
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
             </CardContent>
           </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Pools Lendários & Slots
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label>Ações Lendárias</Label>
                  <div className="grid grid-cols-2 gap-2">
                    <div>
                      <Label htmlFor="la_current" className="text-xs">
                        Atual
                      </Label>
                      <Input
                        id="la_current"
                        type="number"
                        value={formData.legendary_actions_pool?.current || 0}
                        onChange={(e) =>
                          updateField("legendary_actions_pool", {
                            current: parseInt(e.target.value) || 0,
                            max: formData.legendary_actions_pool?.max || 0,
                          })
                        }
                        className="bg-card"
                      />
                    </div>
                    <div>
                      <Label htmlFor="la_max" className="text-xs">
                        Máximo
                      </Label>
                      <Input
                        id="la_max"
                        type="number"
                        value={formData.legendary_actions_pool?.max || 0}
                        onChange={(e) =>
                          updateField("legendary_actions_pool", {
                            current: formData.legendary_actions_pool?.current || 0,
                            max: parseInt(e.target.value) || 0,
                          })
                        }
                        className="bg-card"
                      />
                    </div>
                  </div>
                </div>
                <div className="space-y-2">
                  <Label>Resistências Lendárias</Label>
                  <div className="grid grid-cols-2 gap-2">
                    <div>
                      <Label htmlFor="lr_current" className="text-xs">
                        Atual
                      </Label>
                      <Input
                        id="lr_current"
                        type="number"
                        value={formData.legendary_resistances?.current || 0}
                        onChange={(e) =>
                          updateField("legendary_resistances", {
                            current: parseInt(e.target.value) || 0,
                            max: formData.legendary_resistances?.max || 0,
                          })
                        }
                        className="bg-card"
                      />
                    </div>
                    <div>
                      <Label htmlFor="lr_max" className="text-xs">
                        Máximo
                      </Label>
                      <Input
                        id="lr_max"
                        type="number"
                        value={formData.legendary_resistances?.max || 0}
                        onChange={(e) =>
                          updateField("legendary_resistances", {
                            current: formData.legendary_resistances?.current || 0,
                            max: parseInt(e.target.value) || 0,
                          })
                        }
                        className="bg-card"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </CardContent>
          </Card>

          <div className="flex gap-3 justify-end">
            <Button type="button" variant="outline" onClick={onCancel}>
              Cancelar
            </Button>
            <Button type="submit" className="glow-silver">
              Salvar Monstro
            </Button>
          </div>
        </CardContent>
      </Card>
    </form>
  );
}

"use client";

import type React from "react";

import { useState } from "react";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import { Badge } from "@/components/ui/badge";
import { Monster } from "@/lib/schemas";
import { Plus, X, Trash2, Award, Info, Wand2 } from "lucide-react";
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "@/components/ui/accordion";
import { CheckboxCircle } from "@/components/ui/checkbox";
import { calculateModifier, formatModifier } from "@/lib/skills";
import { DiceIcon } from "./icons";

interface MonsterFormProps {
  monster?: Monster;
  onSave: (monster: Omit<Monster, "id">) => void;
  onCancel: () => void;
}

const attrMap: Record<string, keyof NonNullable<Monster["attributes"]>> = {
  strength: "str",
  dexterity: "dex",
  constitution: "con",
  intelligence: "int",
  wisdom: "wis",
  charisma: "cha",
};

export function MonsterForm({ monster, onSave, onCancel }: MonsterFormProps) {
  const getMonsterAttributes = () => {
    if (monster?.attributes) {
      return monster.attributes;
    }
    return {
      str: (monster as any)?.strength || 10,
      dex: (monster as any)?.dexterity || 10,
      con: (monster as any)?.constitution || 10,
      int: (monster as any)?.intelligence || 10,
      wis: (monster as any)?.wisdom || 10,
      cha: (monster as any)?.charisma || 10,
    };
  };

  const [formData, setFormData] = useState<Partial<Monster>>({
    name: monster?.name || "",
    index: monster?.index || "",
    type: monster?.type || "",
    subtype: monster?.subtype || "",
    challenge_rating: monster?.challenge_rating || 0,
    hp: monster?.hp || 10,
    maxHp: monster?.maxHp || monster?.hp || 10,
    tempHp: monster?.tempHp || 0,
    hit_dice: monster?.hit_dice || "",
    hit_points_roll: monster?.hit_points_roll || "",
    attributes: getMonsterAttributes(),
    xp: monster?.xp || 0,
    alignment: monster?.alignment || "",
    size: monster?.size || "Medium",
    languages: monster?.languages || "",
    image: monster?.image || "",
    forms: monster?.forms || [],
    armor_class: monster?.armor_class || [],
    speed: monster?.speed || {
      walk: undefined,
      burrow: undefined,
      climb: undefined,
      fly: undefined,
      hover: undefined,
      swim: undefined,
    },
    senses: monster?.senses || {
      blindsight: undefined,
      darkvision: undefined,
      passive_perception: 10,
      tremorsense: undefined,
      truesight: undefined,
    },
    proficiencies: monster?.proficiencies || [],
    damage_immunities: monster?.damage_immunities || [],
    damage_resistances: monster?.damage_resistances || [],
    damage_vulnerabilities: monster?.damage_vulnerabilities || [],
    condition_immunities: monster?.condition_immunities || [],
    actions: monster?.actions || [],
    reactions: monster?.reactions || [],
    special_abilities: monster?.special_abilities || [],
    legendary_actions: monster?.legendary_actions || [],
    legendary_actions_pool: monster?.legendary_actions_pool,
    legendary_resistances: monster?.legendary_resistances,
    spellSlots: monster?.spellSlots,
    abilityUses: monster?.abilityUses || [],
    conditions: monster?.conditions || [],
    concentration: monster?.concentration,
    modifiers: monster?.modifiers || [],
    status: monster?.status || "alive",
    isHomebrew: monster?.isHomebrew || false,
  });

  const getAttrValue = (attrName: string): number => {
    const attrKey = attrMap[attrName];
    return formData.attributes?.[attrKey] || 10;
  };

  const updateField = <K extends keyof Partial<Monster>>(
    field: K,
    value: Partial<Monster>[K],
  ) => {
    setFormData((prev) => ({ ...prev, [field]: value }));
  };

  const addArrayItem = <K extends keyof Partial<Monster>>(
    field: K,
    newItem: any,
  ) => {
    const currentArray = (formData[field] as any[]) || [];
    updateField(field as any, [...currentArray, newItem]);
  };

  const removeArrayItem = <K extends keyof Partial<Monster>>(
    field: K,
    index: number,
  ) => {
    const currentArray = (formData[field] as any[]) || [];
    updateField(
      field as any,
      currentArray.filter((_: any, i) => i !== index),
    );
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const monsterToSave: Omit<Monster, "id"> = {
      index: formData.index || "",
      name: formData.name || "",
      type: formData.type || "",
      subtype: formData.subtype,
      size: formData.size || "Medium",
      alignment: formData.alignment,
      image: formData.image,
      languages: formData.languages,
      forms: formData.forms || [],
      challenge_rating: formData.challenge_rating || 0,
      xp: formData.xp || 0,
      attributes: formData.attributes || {
        str: 10,
        dex: 10,
        con: 10,
        int: 10,
        wis: 10,
        cha: 10,
      },
      hp: formData.hp || 0,
      maxHp: formData.maxHp || formData.hp || 0,
      tempHp: formData.tempHp || 0,
      hit_dice: formData.hit_dice || "",
      hit_points_roll: formData.hit_points_roll || "",
      armor_class: formData.armor_class || [],
      speed: formData.speed || {
        walk: undefined,
        burrow: undefined,
        climb: undefined,
        fly: undefined,
        hover: undefined,
        swim: undefined,
      },
      senses: formData.senses || {
        blindsight: undefined,
        darkvision: undefined,
        passive_perception: 10,
        tremorsense: undefined,
        truesight: undefined,
      },
      proficiencies: formData.proficiencies || [],
      damage_immunities: formData.damage_immunities || [],
      damage_resistances: formData.damage_resistances || [],
      damage_vulnerabilities: formData.damage_vulnerabilities || [],
      condition_immunities: formData.condition_immunities || [],
      actions: formData.actions || [],
      reactions: formData.reactions || [],
      special_abilities: formData.special_abilities || [],
      legendary_actions: formData.legendary_actions || [],
      legendary_actions_pool: formData.legendary_actions_pool,
      legendary_resistances: formData.legendary_resistances,
      spellSlots: formData.spellSlots,
      abilityUses: formData.abilityUses || [],
      status: formData.status || "alive",
      conditions: formData.conditions || [],
      concentration: formData.concentration,
      modifiers: formData.modifiers || [],
      isHomebrew: false,
    };
    onSave(monsterToSave);
  };

  return (
    <form onSubmit={handleSubmit}>
      <Card className="parchment-texture metal-border">
        <CardHeader>
          <CardTitle className="font-sans text-2xl">
            {monster ? "Editar Monstro" : "Novo Monstro"}
          </CardTitle>
          <CardDescription className="font-serif">
            Preencha as informações da criatura
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-6">
          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Informações Básicas
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="name">Nome</Label>
                  <Input
                    id="name"
                    value={formData.name}
                    onChange={(e) => updateField("name", e.target.value)}
                    required
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="type">Tipo</Label>
                  <Input
                    id="type"
                    value={formData.type}
                    onChange={(e) => updateField("type", e.target.value)}
                    placeholder="Ex: Aberration, Beast"
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="subtype">Subtipo</Label>
                  <Input
                    id="subtype"
                    value={formData.subtype}
                    onChange={(e) => updateField("subtype", e.target.value)}
                    placeholder="Ex: (shapechanger), (titan)"
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="size">Tamanho</Label>
                  <select
                    id="size"
                    value={formData.size || "Medium"}
                    onChange={(e) => updateField("size", e.target.value)}
                    className="w-full bg-card border rounded-md px-3 py-2"
                  >
                    <option value="Tiny">Tiny</option>
                    <option value="Small">Small</option>
                    <option value="Medium">Medium</option>
                    <option value="Large">Large</option>
                    <option value="Huge">Huge</option>
                    <option value="Gargantuan">Gargantuan</option>
                  </select>
                </div>
                <div className="space-y-2">
                  <Label htmlFor="alignment">Alinhamento</Label>
                  <Input
                    id="alignment"
                    value={formData.alignment}
                    onChange={(e) => updateField("alignment", e.target.value)}
                    placeholder="Ex: lawful evil"
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="challenge_rating">Desafio (CR)</Label>
                  <Input
                    id="challenge_rating"
                    type="number"
                    step="0.125"
                    value={formData.challenge_rating}
                    onChange={(e) =>
                      updateField(
                        "challenge_rating",
                        parseFloat(e.target.value) || 0,
                      )
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="xp">XP</Label>
                  <Input
                    id="xp"
                    type="number"
                    value={formData.xp}
                    onChange={(e) =>
                      updateField("xp", parseInt(e.target.value) || 0)
                    }
                    className="bg-card"
                  />
                </div>
              </div>
              <div className="space-y-2">
                <Label htmlFor="languages">Idiomas</Label>
                <Input
                  id="languages"
                  value={formData.languages}
                  onChange={(e) => updateField("languages", e.target.value)}
                  placeholder="Ex: Common, Goblin, telepathy 60 ft."
                  className="bg-card"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="image">URL da Imagem</Label>
                <Input
                  id="image"
                  value={formData.image}
                  onChange={(e) => updateField("image", e.target.value)}
                  placeholder="Ex: /api/images/monsters/aboleth.png"
                  className="bg-card"
                />
                {formData.image && (
                  <div className="mt-2 flex items-center gap-2">
                    <img
                      src={`https://www.dnd5eapi.co${formData.image}`}
                      alt="Preview"
                      className="w-16 h-16 object-cover rounded-md border border-border"
                      onError={(e) => {
                        e.currentTarget.style.display = "none";
                      }}
                    />
                    <span className="text-xs text-muted-foreground">
                      Preview da imagem
                    </span>
                  </div>
                )}
              </div>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">Atributos</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                {[
                  { key: "str", label: "FOR" },
                  { key: "dex", label: "DES" },
                  { key: "con", label: "CON" },
                  { key: "int", label: "INT" },
                  { key: "wis", label: "SAB" },
                  { key: "cha", label: "CAR" },
                ].map(({ key, label }) => (
                  <div key={key} className="space-y-2">
                    <Label htmlFor={key}>{label}</Label>
                    <Input
                      id={key}
                      type="number"
                      value={formData.attributes?.[key as keyof typeof formData.attributes] || 10}
                      onChange={(e) =>
                        updateField("attributes", {
                          str: formData.attributes?.str || 10,
                          dex: formData.attributes?.dex || 10,
                          con: formData.attributes?.con || 10,
                          int: formData.attributes?.int || 10,
                          wis: formData.attributes?.wis || 10,
                          cha: formData.attributes?.cha || 10,
                          [key]: parseInt(e.target.value) || 10,
                        } as any)
                      }
                      className="bg-card text-center"
                    />
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Pontos de Vida
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="hp">HP Atual</Label>
                  <Input
                    id="hp"
                    type="number"
                    value={formData.hp}
                    onChange={(e) =>
                      updateField("hp", parseInt(e.target.value) || 0)
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="maxHp">HP Máximo</Label>
                  <Input
                    id="maxHp"
                    type="number"
                    value={formData.maxHp}
                    onChange={(e) =>
                      updateField("maxHp", parseInt(e.target.value) || 0)
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="tempHp">HP Temporário</Label>
                  <Input
                    id="tempHp"
                    type="number"
                    value={formData.tempHp}
                    onChange={(e) =>
                      updateField("tempHp", parseInt(e.target.value) || 0)
                    }
                    className="bg-card"
                  />
                </div>
              </div>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="hit_dice">Dado de Vida</Label>
                  <Input
                    id="hit_dice"
                    value={formData.hit_dice}
                    onChange={(e) => updateField("hit_dice", e.target.value)}
                    placeholder="Ex: 2d8"
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="hit_points_roll">Roll de HP</Label>
                  <Input
                    id="hit_points_roll"
                    value={formData.hit_points_roll}
                    onChange={(e) =>
                      updateField("hit_points_roll", e.target.value)
                    }
                    placeholder="Ex: 2d8+4"
                    className="bg-card"
                  />
                </div>
              </div>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Velocidade & Sentidos
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                <div className="space-y-2">
                  <Label htmlFor="walk" className="text-sm">
                    Andar
                  </Label>
                  <Input
                    id="walk"
                    value={formData.speed?.walk || ""}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        walk: e.target.value,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="fly" className="text-sm">
                    Voar
                  </Label>
                  <Input
                    id="fly"
                    value={formData.speed?.fly || ""}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        fly: e.target.value,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="swim" className="text-sm">
                    Nadar
                  </Label>
                  <Input
                    id="swim"
                    value={formData.speed?.swim || ""}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        swim: e.target.value,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="climb" className="text-sm">
                    Escalar
                  </Label>
                  <Input
                    id="climb"
                    value={formData.speed?.climb || ""}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        climb: e.target.value,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="burrow" className="text-sm">
                    Cavar
                  </Label>
                  <Input
                    id="burrow"
                    value={formData.speed?.burrow || ""}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        burrow: e.target.value,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="hover" className="text-sm">
                    Hover
                  </Label>
                  <select
                    id="hover"
                    value={formData.speed?.hover ? "true" : "false"}
                    onChange={(e) =>
                      updateField("speed", {
                        ...formData.speed,
                        hover: e.target.value === "true",
                      })
                    }
                    className="w-full bg-card border rounded-md px-3 py-2"
                  >
                    <option value="false">Não</option>
                    <option value="true">Sim</option>
                  </select>
                </div>
              </div>
              <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                <div className="space-y-2">
                  <Label htmlFor="darkvision" className="text-sm">
                    Visão no Escuro
                  </Label>
                  <Input
                    id="darkvision"
                    value={formData.senses?.darkvision || ""}
                    onChange={(e) =>
                      updateField("senses", {
                        ...formData.senses,
                        darkvision: e.target.value,
                        passive_perception: formData.senses?.passive_perception || 10,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="blindsight" className="text-sm">
                    Blindsight
                  </Label>
                  <Input
                    id="blindsight"
                    value={formData.senses?.blindsight || ""}
                    onChange={(e) =>
                      updateField("senses", {
                        ...formData.senses,
                        blindsight: e.target.value,
                        passive_perception: formData.senses?.passive_perception || 10,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="tremorsense" className="text-sm">
                    Tremorsense
                  </Label>
                  <Input
                    id="tremorsense"
                    value={formData.senses?.tremorsense || ""}
                    onChange={(e) =>
                      updateField("senses", {
                        ...formData.senses,
                        tremorsense: e.target.value,
                        passive_perception: formData.senses?.passive_perception || 10,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="truesight" className="text-sm">
                    Visão Verdadeira
                  </Label>
                  <Input
                    id="truesight"
                    value={formData.senses?.truesight || ""}
                    onChange={(e) =>
                      updateField("senses", {
                        ...formData.senses,
                        truesight: e.target.value,
                        passive_perception: formData.senses?.passive_perception || 10,
                      })
                    }
                    className="bg-card"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="passive_perception" className="text-sm">
                    Percepção Passiva
                  </Label>
                  <Input
                    id="passive_perception"
                    type="number"
                    value={formData.senses?.passive_perception || 10}
                    onChange={(e) =>
                      updateField("senses", {
                        ...formData.senses,
                        passive_perception: parseInt(e.target.value) || 10,
                      })
                    }
                    className="bg-card"
                  />
                </div>
              </div>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Classe de Armadura
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="space-y-2">
                <Label htmlFor="ac_value">Valor da CA</Label>
                <Input
                  id="ac_value"
                  type="number"
                  value={formData.armor_class?.[0]?.value || ""}
                  onChange={(e) => {
                    const currentAC = formData.armor_class?.[0] || {
                      type: "natural",
                      value: 10,
                    };
                    updateField("armor_class", [
                      {
                        ...currentAC,
                        value: Number.parseInt(e.target.value) || 10,
                      },
                    ]);
                  }}
                  className="bg-card"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="ac_type">Tipo da CA</Label>
                <select
                  id="ac_type"
                  value={formData.armor_class?.[0]?.type || "natural"}
                  onChange={(e) => {
                    const currentAC = formData.armor_class?.[0] || {
                      type: "natural",
                      value: 10,
                    };
                    updateField("armor_class", [
                      { ...currentAC, type: e.target.value as any },
                    ]);
                  }}
                  className="w-full bg-card border rounded-md px-3 py-2"
                >
                  <option value="natural">Natural</option>
                  <option value="dex">Destreza</option>
                  <option value="armor">Armadura</option>
                  <option value="spell">Magia</option>
                  <option value="condition">Condição</option>
                </select>
              </div>
            </CardContent>
          </Card>

          <Accordion
            type="single"
            collapsible
            className="bg-bg-surface rounded-lg border border-border-default p-6 shadow-lg"
          >
            <AccordionItem value="proficiencies-section">
              <AccordionTrigger className="">
                <div className="font-heading flex text-sm uppercase tracking-wider text-text-secondary mr-full flex items-center gap-2">
                  <Award className="w-5 h-5" />
                  Proficiências
                </div>
              </AccordionTrigger>
              <AccordionContent>
                <div className="space-y-4">
                  <div className="mb-4 p-3 bg-arcane-400/10 rounded border border-arcane-400/20">
                    <div className="flex items-center gap-3">
                      <Award className="w-5 h-5 text-arcane-400 flex-shrink-0" />
                      <p className="text-sm text-text-secondary">
                        <span className="font-semibold">Bônus de Proficiência:</span>{" "}
                        +{Math.floor((formData.challenge_rating || 0) + 2)}
                      </p>
                    </div>
                  </div>

                  <div className="mb-4 p-3 bg-arcane-400/10 rounded border border-arcane-400/20">
                    <div className="flex items-start gap-2">
                      <Info className="w-4 h-4 text-arcane-400 mt-0.5 flex-shrink-0" />
                      <div className="text-sm text-text-secondary">
                        <p className="font-semibold">
                          Salvaguardas
                        </p>
                        <p className="text-xs mt-1">
                          Selecione as salvaguardas que o monstro possui.
                        </p>
                      </div>
                    </div>
                  </div>

                  <div className="space-y-3">
                    <h4 className="font-semibold text-text-secondary border-b border-border-default pb-2">
                      Salvaguardas ({formatModifier(calculateModifier(getAttrValue("dexterity")))} DES)
                    </h4>
                    <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                      {[
                        { key: "Saving Throw: STR", label: "FOR", attr: "strength" },
                        { key: "Saving Throw: DEX", label: "DES", attr: "dexterity" },
                        { key: "Saving Throw: CON", label: "CON", attr: "constitution" },
                        { key: "Saving Throw: INT", label: "INT", attr: "intelligence" },
                        { key: "Saving Throw: WIS", label: "SAB", attr: "wisdom" },
                        { key: "Saving Throw: CHA", label: "CAR", attr: "charisma" },
                      ].map((save) => {
                        const isProficient = (formData.proficiencies || []).some(
                          (p: any) => p.proficiency?.name === save.key
                        );
                        const attrValue = getAttrValue(save.attr);
                        const modifier = calculateModifier(attrValue);
                        const profBonus = Math.floor((formData.challenge_rating || 0) + 2);
                        const bonus = modifier + (isProficient ? profBonus : 0);
                        
                        return (
                          <div
                            key={save.key}
                            className={`flex items-center justify-between p-3 rounded border transition-colors ${
                              isProficient
                                ? "bg-arcane-400/10 border-arcane-400/30"
                                : "bg-bg-inset border-border-subtle opacity-40"
                            }`}
                          >
                            <div className="flex items-center gap-3">
                              <CheckboxCircle
                                id={`save-${save.key}`}
                                checked={isProficient}
                                onCheckedChange={() => {
                                  const updated = [...(formData.proficiencies || [])];
                                  if (isProficient) {
                                    updateField(
                                      "proficiencies",
                                      updated.filter(
                                        (p: any) => p.proficiency?.name !== save.key
                                      )
                                    );
                                  } else {
                                    updateField("proficiencies", [
                                      ...updated,
                                      { proficiency: { name: save.key }, value: bonus },
                                    ]);
                                  }
                                }}
                              />
                              <Label
                                htmlFor={`save-${save.key}`}
                                className="text-sm font-medium cursor-pointer"
                              >
                                {save.label}
                              </Label>
                            </div>
                            <span
                              className={`text-sm font-bold ${
                                isProficient
                                  ? "text-arcane-400"
                                  : "text-text-secondary"
                              }`}
                            >
                              {formatModifier(bonus)}
                            </span>
                          </div>
                        );
                      })}
                    </div>
                  </div>

                  <div className="space-y-3">
                    <h4 className="font-semibold text-text-secondary border-b border-border-default pb-2">
                      Skills
                    </h4>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                      {[
                        { key: "Skill: Acrobatics", label: "Acrobacia", attr: "dexterity" },
                        { key: "Skill: Animal Handling", label: "Lidar com Animais", attr: "wisdom" },
                        { key: "Skill: Arcana", label: "Arcanismo", attr: "intelligence" },
                        { key: "Skill: Athletics", label: "Atletismo", attr: "strength" },
                        { key: "Skill: Deception", label: "Enganação", attr: "charisma" },
                        { key: "Skill: History", label: "História", attr: "intelligence" },
                        { key: "Skill: Insight", label: "Intuição", attr: "wisdom" },
                        { key: "Skill: Intimidation", label: "Intimidação", attr: "charisma" },
                        { key: "Skill: Investigation", label: "Investigação", attr: "intelligence" },
                        { key: "Skill: Medicine", label: "Medicina", attr: "wisdom" },
                        { key: "Skill: Nature", label: "Natureza", attr: "intelligence" },
                        { key: "Skill: Perception", label: "Percepção", attr: "wisdom" },
                        { key: "Skill: Performance", label: "Atuação", attr: "charisma" },
                        { key: "Skill: Persuasion", label: "Persuasão", attr: "charisma" },
                        { key: "Skill: Religion", label: "Religião", attr: "intelligence" },
                        { key: "Skill: Sleight of Hand", label: "Prestidigitação", attr: "dexterity" },
                        { key: "Skill: Stealth", label: "Furtividade", attr: "dexterity" },
                        { key: "Skill: Survival", label: "Sobrevivência", attr: "wisdom" },
                      ].map((skill) => {
                        const isProficient = (formData.proficiencies || []).some(
                          (p: any) => p.proficiency?.name === skill.key
                        );
                        const attrValue = getAttrValue(skill.attr);
                        const modifier = calculateModifier(attrValue);
                        const profBonus = Math.floor((formData.challenge_rating || 0) + 2);
                        const bonus = modifier + (isProficient ? profBonus : 0);
                        
                        return (
                          <div
                            key={skill.key}
                            className={`flex items-center justify-between p-3 rounded border transition-colors ${
                              isProficient
                                ? "bg-arcane-400/10 border-arcane-400/30"
                                : "bg-bg-inset border-border-subtle opacity-40"
                            }`}
                          >
                            <div className="flex items-center gap-3">
                              <CheckboxCircle
                                id={`skill-${skill.key}`}
                                checked={isProficient}
                                onCheckedChange={() => {
                                  const updated = [...(formData.proficiencies || [])];
                                  if (isProficient) {
                                    updateField(
                                      "proficiencies",
                                      updated.filter(
                                        (p: any) => p.proficiency?.name !== skill.key
                                      )
                                    );
                                  } else {
                                    updateField("proficiencies", [
                                      ...updated,
                                      { proficiency: { name: skill.key }, value: bonus },
                                    ]);
                                  }
                                }}
                              />
                              <Label
                                htmlFor={`skill-${skill.key}`}
                                className="text-sm font-medium cursor-pointer"
                              >
                                {skill.label}
                              </Label>
                            </div>
                            <span
                              className={`text-sm font-bold ${
                                isProficient
                                  ? "text-arcane-400"
                                  : "text-text-secondary"
                              }`}
                            >
                              {formatModifier(bonus)}
                            </span>
                          </div>
                        );
                      })}
                    </div>
                  </div>

                  <div className="space-y-3">
                    <h4 className="font-semibold text-text-secondary border-b border-border-default pb-2">
                      Outras Proficiências
                    </h4>
                    {(formData.proficiencies || [])
                      .filter((p: any) => !p.proficiency?.name.startsWith("Saving Throw:") && !p.proficiency?.name.startsWith("Skill:"))
                      .map((proficiency: any, idx: number) => {
                        const realIdx = (formData.proficiencies || []).findIndex(
                          (p: any) => p.proficiency?.name === proficiency.proficiency?.name
                        );
                        return (
                          <div
                            key={idx}
                            className="flex items-center gap-3 p-3 rounded border bg-bg-inset border-border-subtle"
                          >
                            <Input
                              value={proficiency.proficiency?.name || ""}
                              onChange={(e) => {
                                const updated = [...(formData.proficiencies || [])];
                                updated[realIdx] = {
                                  ...updated[realIdx],
                                  proficiency: {
                                    ...updated[realIdx].proficiency,
                                    name: e.target.value,
                                  },
                                };
                                updateField("proficiencies", updated);
                              }}
                              placeholder="Nome da proficiência"
                              className="bg-card flex-1"
                            />
                            <Input
                              type="number"
                              value={proficiency.value || 0}
                              onChange={(e) => {
                                const updated = [...(formData.proficiencies || [])];
                                updated[realIdx] = {
                                  ...updated[realIdx],
                                  value: parseInt(e.target.value) || 0,
                                };
                                updateField("proficiencies", updated);
                              }}
                              placeholder="Bônus"
                              className="bg-card w-24"
                            />
                            <Button
                              type="button"
                              variant="destructive"
                              size="icon"
                              onClick={() => removeArrayItem("proficiencies", realIdx)}
                            >
                              <X className="w-4 h-4" />
                            </Button>
                          </div>
                        );
                      })}
                    <Button
                      type="button"
                      variant="outline"
                      onClick={() =>
                        addArrayItem("proficiencies", {
                          proficiency: { name: "" },
                          value: 0,
                        })
                      }
                      className="w-full"
                    >
                      <Plus className="w-4 h-4 mr-2" />
                      Adicionar Proficiência Personalizada
                    </Button>
                  </div>
                </div>
              </AccordionContent>
            </AccordionItem>
          </Accordion>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">
                Imunidades & Resistências
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-3">
              <div className="space-y-2">
                <Label htmlFor="damage_immunities">
                  Imunidades a Dano (separadas por vírgula)
                </Label>
                <Textarea
                  id="damage_immunities"
                  value={(formData.damage_immunities || []).join(", ")}
                  onChange={(e) =>
                    updateField(
                      "damage_immunities",
                      e.target.value
                        .split(",")
                        .map((s) => s.trim())
                        .filter((s) => s),
                    )
                  }
                  placeholder="Ex: fogo, frio"
                  className="bg-card"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="damage_resistances">
                  Resistências a Dano (separadas por vírgula)
                </Label>
                <Textarea
                  id="damage_resistances"
                  value={(formData.damage_resistances || []).join(", ")}
                  onChange={(e) =>
                    updateField(
                      "damage_resistances",
                      e.target.value
                        .split(",")
                        .map((s) => s.trim())
                        .filter((s) => s),
                    )
                  }
                  placeholder="Ex: fogo, frio"
                  className="bg-card"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="damage_vulnerabilities">
                  Vulnerabilidades a Dano (separadas por vírgula)
                </Label>
                <Textarea
                  id="damage_vulnerabilities"
                  value={(formData.damage_vulnerabilities || []).join(", ")}
                  onChange={(e) =>
                    updateField(
                      "damage_vulnerabilities",
                      e.target.value
                        .split(",")
                        .map((s) => s.trim())
                        .filter((s) => s),
                    )
                  }
                  placeholder="Ex: fogo, frio"
                  className="bg-card"
                />
              </div>
              <div className="space-y-2">
                <Label htmlFor="condition_immunities">
                  Imunidades a Condições (separadas por vírgula)
                </Label>
                <Textarea
                  id="condition_immunities"
                  value={(formData.condition_immunities || [])
                    .map((c: any) => c.name)
                    .join(", ")}
                  onChange={(e) =>
                    updateField(
                      "condition_immunities",
                      e.target.value
                        .split(",")
                        .map((s) => ({ name: s.trim(), index: s.trim() }))
                        .filter((c: any) => c.name),
                    )
                  }
                  placeholder="Ex: cegado, atordoado"
                  className="bg-card"
                />
              </div>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">Ações</CardTitle>
            </CardHeader>
            <CardContent className="space-y-3 max-h-96 overflow-y-auto">
              {(formData.actions || []).map((action: any, idx: number) => (
                <div
                  key={idx}
                  className="p-3 border border-border rounded space-y-2"
                >
                  <div className="flex gap-2 items-start">
                    <div className="flex-1 space-y-2">
                      <Input
                        value={action.name}
                        onChange={(e) => {
                          const updated = [...(formData.actions || [])];
                          updated[idx] = {
                            ...updated[idx],
                            name: e.target.value,
                          };
                          updateField("actions", updated);
                        }}
                        placeholder="Nome da ação"
                        className="bg-card"
                      />
                      <Input
                        type="number"
                        value={action.attack_bonus || ""}
                        onChange={(e) => {
                          const updated = [...(formData.actions || [])];
                          updated[idx] = {
                            ...updated[idx],
                            attack_bonus: parseInt(e.target.value) || undefined,
                          };
                          updateField("actions", updated);
                        }}
                        placeholder="Bônus de Ataque"
                        className="bg-card"
                      />
                      <Textarea
                        value={action.desc}
                        onChange={(e) => {
                          const updated = [...(formData.actions || [])];
                          updated[idx] = {
                            ...updated[idx],
                            desc: e.target.value,
                          };
                          updateField("actions", updated);
                        }}
                        placeholder="Descrição"
                        className="bg-card"
                      />
                      <Input
                        value={action.multiattack_type || ""}
                        onChange={(e) => {
                          const updated = [...(formData.actions || [])];
                          updated[idx] = {
                            ...updated[idx],
                            multiattack_type: e.target.value || undefined,
                          };
                          updateField("actions", updated);
                        }}
                        placeholder="Tipo de Multiataque"
                        className="bg-card"
                      />
                    </div>
                    <Button
                      type="button"
                      variant="destructive"
                      size="sm"
                      onClick={() => removeArrayItem("actions", idx)}
                    >
                      X
                    </Button>
                  </div>
                </div>
              ))}
              <Button
                type="button"
                variant="outline"
                onClick={() => addArrayItem("actions", { name: "", desc: "" })}
                className="w-full"
              >
                + Adicionar Ação
              </Button>
            </CardContent>
          </Card>

          <Card className="parchment-texture metal-border">
            <CardHeader>
              <CardTitle className="font-heading text-lg">Reações</CardTitle>
            </CardHeader>
            <CardContent className="space-y-3 max-h-64 overflow-y-auto">
              {(formData.reactions || []).map((reaction: any, idx: number) => (
                <div
                  key={idx}
                  className="p-3 border border-border rounded space-y-2"
                >
                  <div className="flex gap-2 items-start">
                    <div className="flex-1 space-y-2">
                      <Input
                        value={reaction.name}
                        onChange={(e) => {
                          const updated = [...(formData.reactions || [])];
                          updated[idx] = {
